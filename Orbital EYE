TLE_LOCK   = threading.Lock()
TLE_SOURCE = 'fallback'


def fetch_live_tles():
    global TLE_SOURCE
    if not HAS_REQUESTS:
        return
    while True:
        ok = 0
        for sat in CATALOGUE:
            try:
                r = requests.get(
                    f"https://celestrak.org/satcat/tle.php?CATNR={sat['norad']}",
                    timeout=8,
                )
                lines = [l.strip() for l in r.text.strip().splitlines() if l.strip()]
                if len(lines) >= 3 and lines[1].startswith('1') and lines[2].startswith('2'):
                    with TLE_LOCK:
                        TLE_STORE[sat['norad']] = (lines[1], lines[2])
                    ok += 1
            except:
                pass
        if ok:
            TLE_SOURCE = 'live'
            print(f"[TLE] {ok} satellites refreshed from Celestrak")
        time.sleep(600)


def get_position(norad_id):
    with TLE_LOCK:
        entry = TLE_STORE.get(norad_id)
    if not entry:
        return None
    l1, l2 = entry
    if HAS_SGP4:
        try:
            s   = Satrec.twoline2rv(l1, l2)
            now = datetime.now(timezone.utc)
            jd, fr = jday(now.year, now.month, now.day,
                          now.hour, now.minute,
                          now.second + now.microsecond / 1e6)
            e, r, v = s.sgp4(jd, fr)
            if e != 0:
                return None
            x, y, z = r
            gst = (280.46061837 + 360.98564736629 * (jd + fr - 2451545.0)) % 360
            lon = (np.degrees(np.arctan2(y, x)) - gst + 360) % 360
            if lon > 180:
                lon -= 360
            rm  = np.sqrt(x*x + y*y + z*z)
            lat = np.degrees(np.arcsin(np.clip(z / rm, -1, 1)))
            alt = rm - 6371.0
            return lat, lon, alt
        except:
            return None
    else:
        try:
            inc = float(l2[8:16])
            mm  = float(l2[52:63])
            T   = 86400 / mm
            t   = datetime.now(timezone.utc).timestamp() % T
            nu  = 2 * np.pi * t / T
            lat = np.degrees(np.arcsin(np.sin(np.radians(inc)) * np.sin(nu)))
            lon = (np.degrees(nu) * 0.8 + 360) % 360
            if lon > 180:
                lon -= 360
            return lat, lon, 400.0
        except:
            return None


