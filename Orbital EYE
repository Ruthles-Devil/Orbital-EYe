class SatTrack:
    TRAIL_LEN = 120

    def __init__(self):
        self.positions = {}
        self.trails    = {s['norad']: [] for s in CATALOGUE}

        # ── Canvas ───────────────────────────────────────────────
        self.canvas = SceneCanvas(
            title='Orbital EYE — Eye you can trust',
            size=(1600, 900), bgcolor=C['ocean'],
            show=False, keys='interactive',
        )

        # ── Full-window map view ─────────────────────────────────
        self.vmap = self.canvas.central_widget.add_view()
        self.vmap.camera = scene.PanZoomCamera(aspect=1)
        self.vmap.camera.set_range(x=(-185, 185), y=(-95, 95))
        self._build_map()

        # ── Satellite trails ─────────────────────────────────────
        self.trail_vis = {}
        for sat in CATALOGUE:
            tv = scene.visuals.Line(
                pos=np.zeros((2, 2), dtype=np.float32),
                color=(1, 1, 1, 0.5), width=2.0, connect='strip',
                parent=self.vmap.scene,
            )
            self.trail_vis[sat['norad']] = tv

        # ── Satellite markers ────────────────────────────────────
        n = len(CATALOGUE)
        self.mk_pos   = np.zeros((n, 2), dtype=np.float32)
        self.mk_color = np.array(
            [self._parse_color(s['color']) for s in CATALOGUE], dtype=np.float32
        )
        self.mk_size  = np.full(n, 16.0, dtype=np.float32)
        self.markers  = scene.visuals.Markers(parent=self.vmap.scene)
        self._flush_markers()

        # ── Name labels ──────────────────────────────────────────
        self.name_labels = {}
        for sat in CATALOGUE:
            lbl = scene.visuals.Text(
                text=sat['name'], color=sat['color'],
                font_size=10, bold=True,
                pos=(0, 0), parent=self.vmap.scene,
            )
            lbl.visible = False
            self.name_labels[sat['norad']] = lbl

        # ── HUD overlay — pixel-space camera ────────────────────
        self.selected = None
        W, H = self.canvas.size

        self.vhud = self.canvas.central_widget.add_view()
        self.vhud.camera = scene.PanZoomCamera(aspect=None)
        # flip=True so y=0 is screen-top, y=H is screen-bottom
        self.vhud.camera.flip = (False, True)
        self.vhud.camera.set_range(x=(0, W), y=(0, H))

        self._hud_widgets = []
        self._hud_dynamic = {}
        self._build_panel(W, H)

        self.canvas.events.mouse_press.connect(self._on_mouse)
        self.canvas.events.key_press.connect(self._on_key)
        self.canvas.events.resize.connect(self._on_resize)

        self.timer = app.Timer(interval=2.0, connect=self._tick, start=False)
        self.canvas.show()
        self.timer.start()

    def _build_panel(self, W, H):
        p = self.vhud.scene

        # ── Destroy previous widgets ──────────────────────────────
        for w in self._hud_widgets:
            try:
                w.parent = None
            except Exception:
                pass
        self._hud_widgets.clear()
        self._hud_dynamic.clear()

        # ── Y-coordinates (screen-space: 0=top, H=bottom) ────────
        #  panel_top_y   = screen y of the TOP edge of the panel card
        #  panel_bot_y   = screen y of the BOTTOM edge
        panel_bot_y  = H - PANEL_MARGIN
        panel_top_y  = panel_bot_y - PANEL_H
        panel_cx     = PX + PANEL_W / 2.0

        # ── Helper — register a widget ────────────────────────────
        def reg(w):
            self._hud_widgets.append(w)
            return w

        def mk_rect(cx, cy, w, h, color, border_color='#00000000', bw=0):
            r = scene.visuals.Rectangle(
                center=(cx, cy), width=w, height=h,
                color=color, border_color=border_color, border_width=bw,
                parent=p,
            )
            r.visible = False
            return reg(r)

        def mk_text(text, x, y, color, size, bold=False,
                    ax='left', ay='center'):
            t = scene.visuals.Text(
                text=text, color=color, font_size=size, bold=bold,
                pos=(x, y), anchor_x=ax, anchor_y=ay,
                parent=p,
            )
            t.visible = False
            return reg(t)

        self._bg = mk_rect(
            panel_cx, (panel_top_y + panel_bot_y) / 2,
            PANEL_W, PANEL_H,
            color='#04090f',
            border_color='#1abc9c55', bw=1.5,
        )

        # Left accent stripe (3 px, full height, coloured per satellite)
        self._accent = mk_rect(
            PX + 2, (panel_top_y + panel_bot_y) / 2,
            3, PANEL_H,
            color='#1abc9c',
        )

        hdr_cy  = panel_top_y + HDR_H / 2
        hdr_bot = panel_top_y + HDR_H

        self._hdr_bg = mk_rect(
            panel_cx, hdr_cy,
            PANEL_W, HDR_H,
            color='#071810',
            border_color='#1abc9c22', bw=1,
        )

        # Satellite colour dot in header (small square, updated dynamically)
        self._hdr_dot = mk_rect(
            PX + 16, hdr_cy, 8, 8,
            color='#1abc9c',
        )

        # Header satellite name (dynamic)
        self._hdr_name = mk_text(
            '', PX + 26, hdr_cy,
            '#e8fff8', FHDR, bold=True, ax='left', ay='center',
        )
        self._hud_dynamic['hdr_name'] = self._hdr_name

        # Header sub-label on right side
        self._hdr_sub = mk_text(
            'LIVE TELEMETRY', PX + PANEL_W - 12, hdr_cy,
            DIM, 7.0, bold=False, ax='right', ay='center',
        )

        y = hdr_bot + 4    # start just below header, leave 4 px gap

        def section_bar(label, yy):
            """Thin section heading row."""
            bar_cy = yy + SECTION_H / 2
            reg(scene.visuals.Line(
                pos=np.array([[PX + 8, yy], [PX + PANEL_W - 8, yy]], dtype=np.float32),
                color=DIVIDER_COL, width=1, parent=p,
            )).visible = False
            t = mk_text(label.upper(), PX + 12, bar_cy + 1,
                        DIMMER, FSEC, bold=True, ax='left', ay='center')
            return yy + SECTION_H

        def data_row(label, dyn_key, yy,
                     label2=None, dyn_key2=None,
                     col1=(COL1_LABEL, COL1_VALUE),
                     col2=(COL2_LABEL, COL2_VALUE)):

            row_cy = yy + ROW_H / 2
            # Left pair
            mk_text(label, col1[0], row_cy, DIM, FSUB,
                    ax='right', ay='center')
            vt = mk_text('—', col1[1], row_cy, '#4a8a70', FVAL,
                         ax='left', ay='center')
            self._hud_dynamic[dyn_key] = vt

            if label2 and dyn_key2:
                mk_text(label2, col2[0], row_cy, DIM, FSUB,
                        ax='right', ay='center')
                vt2 = mk_text('—', col2[1], row_cy, '#4a8a70', FVAL,
                              ax='left', ay='center')
                self._hud_dynamic[dyn_key2] = vt2
            return yy + ROW_H

        # ── Section: SPACECRAFT HUD
        y = section_bar('Spacecraft', y)
        y = data_row('Agency',  'agency', y)
        y = data_row('Launch',  'launch', y, 'Mass',   'mass')
        y = data_row('Orbit',   'orbit',  y, 'Incl.',  'incl')
        y = data_row('Period',  'period', y, 'Speed',  'speed')
        y += 2
        self._div1 = reg(scene.visuals.Line(
            pos=np.array([[PX + 8, y], [PX + PANEL_W - 8, y]], dtype=np.float32),
            color='#0d2820', width=1, parent=p,
        ))
        self._div1.visible = False
        y += 2

        # ── Section: LIVE POSITION ────────────────────────────────
        y = section_bar('Live Position', y)
        y = data_row('Lat',  'lat', y,
                     'Long', 'lon')
        y = data_row('Altitude',  'alt', y,
                     'NORAD ID',  'norad')

        y += 2
        self._div2 = reg(scene.visuals.Line(
            pos=np.array([[PX + 8, y], [PX + PANEL_W - 8, y]], dtype=np.float32),
            color='#0d2820', width=1, parent=p,
        ))
        self._div2.visible = False
        y += 4

        # ── Note / extras row ─────────────────────────────────────
        self._note = mk_text('', PX + 12, y + ROW_H / 2,
                             '#2e6655', 7.5, ax='left', ay='center')
        self._hud_dynamic['note'] = self._note

        y += ROW_H + 2

        self._extras = mk_text('', PX + 12, y + ROW_H / 2,
                               '#1e4a38', 7.0, ax='left', ay='center')
        self._hud_dynamic['extras'] = self._extras

        # ── Esc hint (bottom-right of card) ───────────────────────
        hint_y = panel_bot_y - 8
        self._hint = mk_text('[Esc] close', PX + PANEL_W - 10, hint_y,
                             '#1a3d30', 6.5, ax='right', ay='bottom')

        # Store panel geometry for _show_panel
        self._panel_visible = False

    def _show_panel(self, visible):
        self._panel_visible = visible
        for w in self._hud_widgets:
            w.visible = visible

    def _update_panel(self):
        if self.selected is None:
            return
        sat = CATALOGUE[self.selected]
        nid = sat['norad']
        pos = self.positions.get(nid)
        sc  = sat['color']

        # Accent stripe + dot use the satellite colour
        col_rgba = self._parse_color(sc)
        self._accent.color      = col_rgba
        self._hdr_dot.color     = col_rgba
        self._hdr_bg.border_color = sc + '33'

        # Header name
        d = self._hud_dynamic
        d['hdr_name'].text  = sat['name'].upper()
        d['hdr_name'].color = sc

        # Spacecraft fields
        d['agency'].text  = sat['agency']
        d['launch'].text  = sat['launch']
        d['mass'].text    = sat['mass']
        d['orbit'].text   = sat['altitude']
        d['incl'].text    = sat['incl']
        d['period'].text  = sat['period']
        d['speed'].text   = sat['speed']
        d['norad'].text   = f"#{nid}"

        # Set value text colours to satellite colour (dimmed)
        for key in ('agency','launch','mass','orbit','incl','period','speed','norad'):
            d[key].color = sc

        # Live position
        if pos:
            lat, lon, alt = pos
            d['lat'].text = f"{abs(lat):.4f}°  {'N' if lat >= 0 else 'S'}"
            d['lon'].text = f"{abs(lon):.4f}°  {'E' if lon >= 0 else 'W'}"
            d['alt'].text = f"{alt:,.1f} km"
            for key in ('lat', 'lon', 'alt'):
                d[key].color = '#e0fff8'   # brighter white for live data
        else:
            for key in ('lat', 'lon', 'alt'):
                d[key].text  = 'fetching…'
                d[key].color = DIM

        # Note + extras
        d['note'].text   = sat.get('note', '')
        d['extras'].text = sat.get('extras', '')

        self._show_panel(True)

    # ═══════════════════════════════════════════════════════════
    def _on_resize(self, event):
        W, H = event.size
        self.vhud.camera.set_range(x=(0, W), y=(0, H))
        self._build_panel(W, H)
        if self.selected is not None:
            self._update_panel()

    def _on_mouse(self, event):
        if event.button != 1:
            return
        tr  = self.vmap.scene.transform
        pos = tr.imap(event.pos)
        cx, cy = float(pos[0]), float(pos[1])

        best, bd = None, 5.0
        for i, sat in enumerate(CATALOGUE):
            p = self.positions.get(sat['norad'])
            if p is None:
                continue
            lat, lon, _ = p
            d = np.hypot(lon - cx, lat - cy)
            if d < bd:
                bd = d; best = i

        if best is not None:
            self.selected = best
            for i in range(len(CATALOGUE)):
                self.mk_size[i]  = 28.0 if i == best else 16.0
                self.mk_color[i] = (1, 1, 1, 1) if i == best \
                                   else self._parse_color(CATALOGUE[i]['color'])
            self._flush_markers()
            self._update_panel()
        else:
            self._deselect()

    def _deselect(self):
        self.selected = None
        for i, sat in enumerate(CATALOGUE):
            self.mk_size[i]  = 16.0
            self.mk_color[i] = self._parse_color(sat['color'])
        self._flush_markers()
        self._show_panel(False)

    def _build_map(self):
        p = self.vmap.scene
        scene.visuals.Rectangle(
            center=(0, 0), width=370, height=185,
            color='#05111f', border_color='#05111f', parent=p,
        )
        for name, pts in LAND_POLYGONS.items():
            arr = np.array(pts, dtype=np.float32)
            arr2 = np.vstack([arr, arr[0:1]])
            scene.visuals.Line(pos=arr2, color='#142e1e',
                               width=1, connect='strip', parent=p)
        for lon in range(-180, 181, 30):
            scene.visuals.Line(
                pos=np.array([[lon, -90], [lon, 90]], dtype=np.float32),
                color='#0a1f2e', width=0.7, parent=p)
        for lat in range(-90, 91, 30):
            scene.visuals.Line(
                pos=np.array([[-180, lat], [180, lat]], dtype=np.float32),
                color='#0a1f2e', width=0.7, parent=p)
        for lon in range(-150, 181, 30):
            lbl = 'E' if lon > 0 else ('W' if lon < 0 else '')
            scene.visuals.Text(text=f"{abs(lon)}{lbl}", color='#1a4a38',
                               font_size=7, pos=(lon, -87), parent=p)
        for lat in range(-60, 91, 30):
            lbl = 'N' if lat > 0 else ('S' if lat < 0 else '')
            if lat == 0: lbl = ''
            scene.visuals.Text(text=f"{abs(lat)}{lbl}", color='#1a4a38',
                               font_size=7, pos=(-178, lat), parent=p)
        segs = (build_coast_segments_cartopy() if HAS_CARTOPY else None) \
               or build_coast_segments_fallback()
        for seg in segs:
            if len(seg) < 2: continue
            scene.visuals.Line(
                pos=np.array(seg, dtype=np.float32)[:, :2],
                color='#2ecc71', width=1.5, connect='strip', parent=p)
        scene.visuals.Line(
            pos=np.array([[-180, 0], [180, 0]], dtype=np.float32),
            color='#1abc9c66', width=1.5, parent=p)
        scene.visuals.Line(
            pos=np.array([[0, -90], [0, 90]], dtype=np.float32),
            color='#1abc9c44', width=1.0, parent=p)
        border = np.array(
            [[-180,-90],[180,-90],[180,90],[-180,90],[-180,-90]], dtype=np.float32)
        scene.visuals.Line(pos=border, color='#1abc9c88', width=1.5, parent=p)

    def _flush_markers(self):
        self.markers.set_data(
            pos=self.mk_pos,
            face_color=self.mk_color,
            edge_color=np.ones_like(self.mk_color),
            edge_width=2.0,
            size=self.mk_size,
        )

    @staticmethod
    def _parse_color(hex_str):
        h = hex_str.lstrip('#')
        return tuple(int(h[i:i+2], 16) / 255.0 for i in (0, 2, 4)) + (1.0,)

    def _on_key(self, event):
        if event.key == 'Escape':
            self._deselect()

    def _tick(self, event):
        now    = datetime.now(timezone.utc)
        active = 0

        for i, sat in enumerate(CATALOGUE):
            nid = sat['norad']
            pos = get_position(nid)

            if pos is None:
                self.mk_pos[i] = [0, -200]
                self.name_labels[nid].visible = False
                continue

            lat, lon, alt = pos
            self.positions[nid] = pos
            active += 1

            self.mk_pos[i] = [lon, lat]
            if self.selected != i:
                self.mk_color[i] = self._parse_color(sat['color'])

            lbl = self.name_labels[nid]
            lbl.pos     = (lon + 3, lat + 3)
            lbl.visible = True

            hist = self.trails[nid]
            hist.append([lon, lat])
            if len(hist) > self.TRAIL_LEN:
                hist.pop(0)

            if len(hist) >= 2:
                pts, prev = [], None
                for pt in hist:
                    if prev is not None and abs(pt[0] - prev) > 150:
                        pts.append([np.nan, np.nan])
                    pts.append(pt)
                    prev = pt[0]
                arr = np.array(pts, dtype=np.float32)
                n   = len(arr)
                r, g, b, _ = self._parse_color(sat['color'])
                alphas = np.linspace(0.06, 0.80, n)
                colors = np.column_stack([
                    np.full(n, r), np.full(n, g),
                    np.full(n, b), alphas,
                ]).astype(np.float32)
                self.trail_vis[nid].set_data(pos=arr, color=colors)

        self._flush_markers()
        if self.selected is not None:
            self._update_panel()

        sgp = 'SGP4' if HAS_SGP4 else 'simplified'
        print(f"\r[{now.strftime('%H:%M:%S')} utc]  "
              f"{active}/{len(CATALOGUE)} active  |  "
              f"TLE: {TLE_SOURCE}  |  propagator: {sgp}   ",
              end='', flush=True)

    def run(self):
        app.run()


