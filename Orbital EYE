def build_coast_segments_fallback():
    segs = []
    for name, pts in LAND_POLYGONS.items():
        arr = np.array(pts, dtype=np.float32)
        arr = np.vstack([arr, arr[0:1]])
        segs.append(arr)
    return segs


def build_coast_segments_cartopy():
    try:
        fn = shpreader.natural_earth(resolution='50m', category='physical', name='coastline')
        reader = shpreader.Reader(fn)
        segs = []
        for geom in reader.geometries():
            if geom.geom_type == 'LineString':
                segs.append(np.array(geom.coords, dtype=np.float32))
            elif geom.geom_type == 'MultiLineString':
                for part in geom.geoms:
                    segs.append(np.array(part.coords, dtype=np.float32))
        print(f"[MAP] Cartopy: {len(segs)} coastline segments loaded")
        return segs
    except Exception as e:
        print(f"[MAP] Cartopy failed: {e}, using fallback")
        return None

